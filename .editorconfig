root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 120
# intellij_idea стиль — без жёстких требований trailing-comma/multiline-wrapping.
# ktlint_official слишком агрессивен для повседневного развития.
ktlint_code_style = intellij_idea
ktlint_function_naming_ignore_when_annotated_with = Composable
ktlint_standard_filename = disabled
# Слишком агрессивные правила: пытаются переформатировать на one-line или
# конфликтуют с trailing-comma multi-line стилем.
ktlint_standard_function-signature = disabled
ktlint_standard_function-signature-body-expression-wrapping = disabled
ktlint_standard_function-expression-body = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_parameter-list-wrapping = disabled
ktlint_standard_parameter-wrapping = disabled
ktlint_standard_argument-list-wrapping = disabled
ktlint_standard_class-signature = disabled
ktlint_standard_import-ordering = disabled
ktlint_standard_backing-property-naming = disabled
ktlint_standard_property-naming = disabled
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

[*.xml]
indent_size = 4
max_line_length = off

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab
