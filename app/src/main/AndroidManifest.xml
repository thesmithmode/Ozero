<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Android 13 (API 33+): runtime-permission, без неё system-tray notification VPN не покажет -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Android 8+ (API 26+): self-update через PackageInstaller (RT.7) — иначе install upd APK падает -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
        RT.7.3: опциональный whitelist от Doze. Без permission'а system отказывает в
        ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS Intent'е (SecurityException).
        Prompt показывается один раз — VPN работает и без него, но с Doze possible drops.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
        ACCESS_NETWORK_STATE: probe-логика (CGNAT detector, network type) опирается на
        ConnectivityManager.getNetworkCapabilities — без permission возвращает null,
        StrategyEngine.udpReachable не сможет принять решение.
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".OzeroApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ozero"
        android:usesCleartextTraffic="false"
        android:enableOnBackInvokedCallback="true"><!-- RT.7.4: Predictive Back на Android 14+ -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- RT.8.1: deeplinks для импорта одиночных серверов через VPN-схемы -->
            <intent-filter android:label="@string/app_name">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="vless" />
                <data android:scheme="hy2" />
                <data android:scheme="hysteria2" />
                <data android:scheme="trojan" />
                <data android:scheme="ss" />
                <data android:scheme="tuic" />
                <data android:scheme="vmess" />
                <data android:scheme="awg" />
            </intent-filter>

            <!-- RT.8.1: HTTPS-deeplink на subscription-домен (autoVerify требует assetlinks.json) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="sub.ozero.app" />
            </intent-filter>

            <!-- RT.8.2: share-target для текста подписки -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- RT.6.1: result-broadcast от PackageInstaller.commit() при self-update -->
        <receiver
            android:name=".selfupdate.UpdateInstallResultReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="ru.ozero.app.UPDATE_INSTALL_RESULT" />
            </intent-filter>
        </receiver>

        <!-- E16.1: отключаем default WorkManager auto-init, используем custom Configuration.Provider в OzeroApp -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- RT.11.1: FileProvider для экспорта crash log из filesDir/crashes/ -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <service
            android:name=".OzeroQuickTile"
            android:exported="true"
            android:icon="@android:drawable/ic_lock_lock"
            android:label="Ozero VPN"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
