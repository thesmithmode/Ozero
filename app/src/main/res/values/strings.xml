    <!-- URnetwork -->
    <string name="urnetwork_settings_title">URnetwork</string>
    <string name="urnetwork_consent_warning_title">Внимание</string>
    <string name="urnetwork_consent_warning_body">URnetwork — P2P-сеть, в которой каждый участник может работать как exit-node. Если вы включите URnetwork, ваше устройство будет передавать чужой трафик в открытый интернет от своего IP-адреса. Это может приводить к подозрениям со стороны провайдера и юридическим рискам в некоторых юрисдикциях. Включайте только если понимаете последствия.</string>
