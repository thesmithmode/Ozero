    <!-- URnetwork -->
    <string name="urnetwork_settings_title">URnetwork</string>
    <string name="urnetwork_consent_warning_title">Внимание</string>
    <string name="urnetwork_consent_warning_body">URnetwork — P2P-сеть, в которой каждый участник может работать как exit-node. Если вы включите URnetwork, ваше устройство будет передавать чужой трафик в открытый интернет от своего IP-адреса. Это может приводить к подозрениям со стороны провайдера и юридическим рискам в некоторых юрисдикциях. Включайте только если понимаете последствия. За exit-node трафик начисляются токены URx на Solana-кошелёк.</string>
    <string name="urnetwork_search_hint">Поиск по стране…</string>
    <string name="urnetwork_location_title">Регион выхода</string>
    <string name="urnetwork_location_best_available">Лучший доступный</string>
    <string name="urnetwork_location_connect_first">Подключитесь к URnetwork чтобы увидеть доступные регионы</string>
    <string name="urnetwork_provide_title">Предоставлять трафик</string>
    <string name="urnetwork_provide_subtitle">Делиться пропускной способностью с сетью URnetwork</string>
    <string name="urnetwork_peers_connected">Подключено к %1$d peer-ам</string>
    <string name="urnetwork_peers_searching">Поиск peer-ов…</string>
    <string name="urnetwork_about_title">Что такое URnetwork</string>
    <string name="urnetwork_about_body">URnetwork — самая локальная и приватная сеть в мире. Запатентованный протокол держит участников в безопасности. Сейчас в сети больше 30 000 провайдеров, известных инцидентов — ноль.</string>
    <string name="settings_urnetwork_title">URnetwork</string>
    <string name="settings_urnetwork_summary">P2P mesh — exit-node + Solana-кошелёк</string>

