<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config.

    Запрещает cleartext HTTP трафик, кроме routed connectivity probes.
    User-installed CA certificates НЕ доверяются — это ломает установленные
    вручную сертификаты MITM-инструментов (mitmproxy / Charles / РКН-issued root).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">connectivitycheck.gstatic.com</domain>
        <domain includeSubdomains="false">cp.cloudflare.com</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
