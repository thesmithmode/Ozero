# Auto-normalize line endings
* text=auto eol=lf

# Shell/Unix scripts — ВСЕГДА LF (шебанг ломается при CRLF)
*.sh text eol=lf
*.bash text eol=lf
Dockerfile text eol=lf
Dockerfile.* text eol=lf
gradlew text eol=lf
Makefile text eol=lf
*.mk text eol=lf

# Windows batch — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
gradlew.bat text eol=crlf

# Kotlin / Java / config — LF
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.pro text eol=lf

# Бинарные
*.jar binary
*.aar binary
*.so binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.keystore binary
*.jks binary
*.apk binary
*.aab binary
*.dex binary
*.class binary

# Gradle wrapper
gradle/wrapper/gradle-wrapper.jar binary
