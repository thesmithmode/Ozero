<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        Android 14+ (API 34) обязывает декларировать тип FGS. Для VPN-сервисов нет
        специального типа: SYSTEM_EXEMPTED закрыт для regular apps, CONNECTED_DEVICE
        требует физического USB/Bluetooth/CDM. Рекомендация Google для VPN custom
        services — `specialUse` с пояснительной meta-data.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application>
        <service
            android:name=".OzeroVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>

</manifest>
